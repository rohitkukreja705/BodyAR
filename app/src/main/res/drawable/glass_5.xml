<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="80dp"
    android:viewportWidth="100"
    android:viewportHeight="40">

    <!-- left temple -->
    <path android:fillColor="@color/glass_5_dark" android:pathData="M0,10 L8,12 L8,16 L0,15 Z" />
    <!-- right temple -->
    <path android:fillColor="@color/glass_5_dark" android:pathData="M92,10 L100,10 L100,15 L92,16 Z" />

    <!-- left lens -->
    <path android:pathData="M8,8 C8,4 16,2 26,2 C36,2 42,6 42,14 C42,22 36,26 26,26 C16,26 8,22 8,16 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="8" android:startY="2" android:endX="42" android:endY="26"
                android:startColor="@color/glass_5_light" android:endColor="@color/glass_5_dark" />
        </aapt:attr>
    </path>
    <!-- right lens -->
    <path android:pathData="M58,8 C58,4 66,2 76,2 C86,2 92,6 92,14 C92,22 86,26 76,26 C66,26 58,22 58,16 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="58" android:startY="2" android:endX="92" android:endY="26"
                android:startColor="@color/glass_5_light" android:endColor="@color/glass_5_dark" />
        </aapt:attr>
    </path>

    <!-- bridge -->
    <path android:fillColor="@color/glass_5_dark" android:pathData="M42,10 L58,10 L58,14 L42,14 Z" />

    <!-- lens rim -->
    <path android:fillColor="#00000000" android:strokeColor="#40000000" android:strokeWidth="0.6"
        android:pathData="M8,8 C8,4 16,2 26,2 C36,2 42,6 42,14 C42,22 36,26 26,26 C16,26 8,22 8,16 Z" />
    <path android:fillColor="#00000000" android:strokeColor="#40000000" android:strokeWidth="0.6"
        android:pathData="M58,8 C58,4 66,2 76,2 C86,2 92,6 92,14 C92,22 86,26 76,26 C66,26 58,22 58,16 Z" />

    <!-- glossy shine streak -->
    <path android:fillColor="#55FFFFFF" android:pathData="M13,7 C17,4 22,4 24,6 L17,13 Z" />
    <path android:fillColor="#55FFFFFF" android:pathData="M63,7 C67,4 72,4 74,6 L67,13 Z" />
</vector>
